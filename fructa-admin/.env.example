# Supabase — Settings -> API Keys
NEXT_PUBLIC_SUPABASE_URL=https://lxtyrtgyfrhxyjraroku.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://lxtyrtgyfrhxyjraroku.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # SERVER ONLY — never expose to the app

# Cron auth — Vercel auto-provides CRON_SECRET in production.
# Set your own here for local dev so the route accepts your requests.
CRON_SECRET=generate-a-random-32-char-string

# OneSignal (later phase)
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=
